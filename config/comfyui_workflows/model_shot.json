{
  "1": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "{input_image}"
    },
    "_meta": { "title": "Load Reference Product" }
  },
  "2": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "sd_xl_base_1.0.safetensors"
    },
    "_meta": { "title": "Load SDXL Base" }
  },
  "3": {
    "class_type": "LoraLoader",
    "inputs": {
      "lora_name": "{lora_name}",
      "strength_model": 0.85,
      "strength_clip": 0.85,
      "model": ["2", 0],
      "clip": ["2", 1]
    },
    "_meta": { "title": "Load LoRA" }
  },
  "4": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{prompt}",
      "clip": ["3", 1]
    },
    "_meta": { "title": "Positive Prompt" }
  },
  "5": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "blurry, bad quality, distorted, extra jewelry, watermark, deformed hands",
      "clip": ["3", 1]
    },
    "_meta": { "title": "Negative Prompt" }
  },
  "6": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": 1024,
      "height": 1024,
      "batch_size": 1
    },
    "_meta": { "title": "Empty Latent" }
  },
  "7": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["3", 0],
      "positive": ["4", 0],
      "negative": ["5", 0],
      "latent_image": ["6", 0],
      "seed": 42,
      "steps": 30,
      "cfg": 7.5,
      "sampler_name": "euler",
      "scheduler": "normal",
      "denoise": 1.0
    },
    "_meta": { "title": "KSampler" }
  },
  "8": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["7", 0],
      "vae": ["2", 2]
    },
    "_meta": { "title": "VAE Decode" }
  },
  "9": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["8", 0],
      "filename_prefix": "model_shot"
    },
    "_meta": { "title": "Save Output" }
  }
}
